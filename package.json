{
  "name": "emberprobe",
  "displayName": "EmberProbe - MCU Flash & Debug",
  "description": "Modern MCU flashing and debugging with OpenOCD, automatic target detection, and an Agent Skill.",
  "version": "0.3.1",
  "publisher": "BakeSheep",
  "repository": {
    "type": "git",
    "url": "https://github.com/BakeSheep/EmberProbe-MCU-Flash-Debug.git"
  },
  "homepage": "https://github.com/BakeSheep/EmberProbe-MCU-Flash-Debug#readme",
  "bugs": {
    "url": "https://github.com/BakeSheep/EmberProbe-MCU-Flash-Debug/issues"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Debuggers"
  ],
  "keywords": [
    "MCU",
    "OpenOCD",
    "flash",
    "debug",
    "ELF",
    "SVD",
    "Cortex-M",
    "embedded",
    "agent"
  ],
  "icon": "media/icon.png",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onView:mcu-vscode.mainView",
    "onCommand:mcu-vscode.folderDebug",
    "onCommand:mcu-vscode.folderDownload",
    "onCommand:mcu-vscode.openLiveWatch",
    "onCommand:mcu-vscode.checkOpenOcd"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mcu-vscode-container",
          "title": "EmberProbe",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "mcu-vscode-container": [
        {
          "type": "webview",
          "id": "mcu-vscode.mainView",
          "name": "Flash & Debug"
        }
      ]
    },
    "commands": [
      {
        "command": "mcu-vscode.folderDebug",
        "title": "EmberProbe: 启动调试"
      },
      {
        "command": "mcu-vscode.folderDownload",
        "title": "EmberProbe: 下载程序"
      },
      {
        "command": "mcu-vscode.openLiveWatch",
        "title": "EmberProbe: 实时变量查看"
      },
      {
        "command": "mcu-vscode.checkOpenOcd",
        "title": "EmberProbe: 检查 OpenOCD 环境"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "mcu-vscode.folderDebug",
          "group": "mcu-vscode@1",
          "when": "explorerResourceIsFolder"
        },
        {
          "command": "mcu-vscode.folderDownload",
          "group": "mcu-vscode@2",
          "when": "explorerResourceIsFolder"
        }
      ]
    },
    "configuration": {
      "title": "EmberProbe 配置",
      "properties": {
        "emberprobe.openocdPath": {
          "type": "string",
          "default": "openocd",
          "description": "OpenOCD 可执行文件路径；不在 PATH 时请填写 openocd.exe 的绝对路径"
        },
        "emberprobe.tclPort": {
          "type": "number",
          "default": 6666,
          "description": "实时变量查看使用的 OpenOCD Tcl-RPC 端口"
        },
        "emberprobe.sampleIntervalMs": {
          "type": "number",
          "default": 100,
          "description": "实时变量采样间隔（毫秒），最小 20ms"
        },
        "emberprobe.maxSamples": {
          "type": "number",
          "default": 2000,
          "description": "实时曲线每个通道保留的最大采样点数"
        }
      }
    }
  },
  "files": [
    "dist/extension.js",
    "resources/**/*.tar.gz",
    "media/**/*",
    "skills/**/*",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "check": "node --check src/extension.js && node --check src/modernView.js && node --check src/i18n.js && node --check src/autoDetect.js && node --check src/openocdRunner.js && node --check src/openocdChecker.js && node --check src/openocdInstaller.js && node --check src/elfSymbols.js && node --check src/dwarf.js && node --check src/chipInfo.js && node --check src/liveWatch.js && node --check src/liveWatchView.js && node test/openocd-parser.test.js && node test/elf-symbols.test.js && node test/webview.test.js && node test/openocd-checker.test.js && node test/openocd-installer.test.js && node test/chip-info.test.js",
    "bundle": "node esbuild.js",
    "vscode:prepublish": "npm run bundle",
    "package": "npx --yes @vscode/vsce package --out dist/emberprobe.vsix"
  },
  "dependencies": {
    "tar": "^7.5.20"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
